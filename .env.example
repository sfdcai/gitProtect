# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub OAuth (set these in Supabase dashboard, not needed here directly)
# GITHUB_CLIENT_ID=your_github_oauth_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Scanner Worker Secret (shared secret between Next.js and the worker)
SCANNER_WORKER_SECRET=a_strong_random_secret_string

# Optional: GitHub Personal Access Token for higher API rate limits (public repos)
GITHUB_PAT=your_github_personal_access_token
